<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.project.controller.AuthController"
      alignment="CENTER" spacing="15"
      prefWidth="400" prefHeight="300">

    <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

    <Label text="Sistema de Trenes" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    <TextField fx:id="txtUsuario" promptText="Usuario"/>
    <PasswordField fx:id="txtPassword" promptText="Contraseña"/>
    <Label fx:id="lblError" style="-fx-text-fill: red;" text=""/>
    <Button text="Iniciar Sesión" onAction="#handleLogin"
            prefWidth="200"
            style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
</VBox>