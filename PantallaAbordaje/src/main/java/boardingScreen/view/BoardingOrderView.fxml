<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="boardingScreen.controller.BoardingOrderController"
      styleClass="raiz" spacing="0">

    <!-- Top bar -->
    <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="12">
        <Button fx:id="btnSeleccionarRuta" text="← Seleccionar otra ruta"
                styleClass="btn-volver" onAction="#handleSeleccionarOtraRuta"
                prefHeight="36"/>
        <Region HBox.hgrow="ALWAYS"/>
        <VBox spacing="2" alignment="CENTER_RIGHT">
            <Label fx:id="lblRutaNombre" text="Ruta" styleClass="header-titulo"/>
            <Label fx:id="lblRutaDetalle" text="" styleClass="header-sub"/>
        </VBox>
    </HBox>

    <!-- Barra de progreso -->
    <VBox styleClass="progreso-bar-container" spacing="4">
        <HBox alignment="CENTER_RIGHT">
            <Label fx:id="lblProgreso" text="0 / 0" styleClass="label-progreso"/>
        </HBox>
        <ProgressBar fx:id="progressBar" progress="0" maxWidth="Infinity"
                     prefHeight="8" styleClass="progress-abordaje"/>
    </VBox>

    <!-- Contenido central -->
    <StackPane VBox.vgrow="ALWAYS" styleClass="contenido-central">

        <VBox alignment="CENTER" spacing="28" maxWidth="620">

            <!-- Turno actual -->
            <VBox styleClass="card-turno" spacing="10" alignment="CENTER">
                <Label fx:id="lblTurnoActual" text="Turno —" styleClass="turno-numero"/>
                <Label fx:id="lblNombrePasajero" text="Esperando..."
                       styleClass="nombre-pasajero" wrapText="true" maxWidth="500"/>
                <HBox alignment="CENTER" spacing="20">
                    <HBox styleClass="badge-cat" alignment="CENTER">
                        <Label fx:id="lblCategoria" text="" styleClass="badge-cat-texto"/>
                    </HBox>
                    <HBox styleClass="badge-vagon" alignment="CENTER">
                        <Label fx:id="lblVagon" text="" styleClass="badge-vagon-texto"/>
                    </HBox>
                </HBox>
            </VBox>

            <!-- Pasajero anterior -->
            <VBox fx:id="panelAnterior" styleClass="card-anterior" spacing="4"
                  alignment="CENTER" visible="false" managed="false">
                <Label text="Pasajero anterior" styleClass="anterior-titulo"/>
                <Label fx:id="lblAnteriorNombre" text="" styleClass="anterior-nombre"/>
                <Label fx:id="lblAnteriorDetalle" text="" styleClass="anterior-detalle"/>
            </VBox>

            <!-- Estado final -->
            <Label fx:id="lblEstado" text="" styleClass="label-completado"
                   visible="false" wrapText="true" maxWidth="500" alignment="CENTER"/>

        </VBox>

    </StackPane>

    <!-- Footer con controles -->
    <HBox styleClass="footer-bar" alignment="CENTER" spacing="16" prefHeight="62">
        <Button fx:id="btnPausarReanudar" text="⏸  Pausar"
                styleClass="btn-secundario" prefHeight="40" prefWidth="160"
                onAction="#handlePausarReanudar"/>
    </HBox>

</VBox>
