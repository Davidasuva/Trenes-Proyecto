<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="edu.project.controller.RegisterController"
           styleClass="raiz">

    <VBox styleClass="card"
          spacing="0"
          alignment="CENTER"
          maxWidth="420">

        <!-- Logo -->
        <HBox alignment="CENTER" spacing="10">
            <ImageView fitWidth="52" fitHeight="52" preserveRatio="true">
                <image>
                    <Image url="@train-travel-round-icon2-by-Vexels.png"/>
                </image>
            </ImageView>
            <Label text="trenes" styleClass="logo-texto"/>
        </HBox>

        <Region minHeight="24" maxHeight="24"/>

        <!-- Usuario -->
        <TextField fx:id="txtUsuario"
                   promptText="Usuario"
                   styleClass="campo"
                   maxWidth="340"/>

        <Region minHeight="10" maxHeight="10"/>

        <!-- Correo -->
        <TextField fx:id="txtCorreo"
                   promptText="Correo electrónico"
                   styleClass="campo"
                   maxWidth="340"/>

        <Region minHeight="10" maxHeight="10"/>

        <!-- Contraseña -->
        <StackPane maxWidth="340">
            <PasswordField fx:id="txtPassword"
                           promptText="Contraseña"
                           styleClass="campo"/>
            <TextField fx:id="txtPasswordVisible"
                       promptText="Contraseña"
                       styleClass="campo"
                       visible="false"/>
            <Button fx:id="btnOjo1" text="👁"
                    styleClass="btn-ojo"
                    onAction="#handleTogglePassword1"
                    StackPane.alignment="CENTER_RIGHT">
                <StackPane.margin><Insets right="10"/></StackPane.margin>
            </Button>
        </StackPane>

        <Region minHeight="10" maxHeight="10"/>

        <!-- Confirmar contraseña -->
        <StackPane maxWidth="340">
            <PasswordField fx:id="txtConfirm"
                           promptText="Confirmar contraseña"
                           styleClass="campo"/>
            <TextField fx:id="txtConfirmVisible"
                       promptText="Confirmar contraseña"
                       styleClass="campo"
                       visible="false"/>
            <Button fx:id="btnOjo2" text="👁"
                    styleClass="btn-ojo"
                    onAction="#handleTogglePassword2"
                    StackPane.alignment="CENTER_RIGHT">
                <StackPane.margin><Insets right="10"/></StackPane.margin>
            </Button>
        </StackPane>

        <!-- Error -->
        <Label fx:id="lblError"
               styleClass="label-error"
               maxWidth="340"
               wrapText="true"
               visible="false">
            <VBox.margin><Insets top="5"/></VBox.margin>
        </Label>

        <Region minHeight="16" maxHeight="16"/>

        <!-- Botón Registrar -->
        <Button fx:id="btnRegistrar"
                text="Crear cuenta"
                styleClass="btn-ingresar"
                maxWidth="340"
                prefHeight="44"
                onAction="#handleRegister"/>

        <Region minHeight="22" maxHeight="22"/>

        <!-- Volver al login -->
        <Label text="¿Ya tienes cuenta?" styleClass="texto-registro"/>
        <Label fx:id="lblIniciarSesion"
               text="Inicia sesión"
               styleClass="link-registro"
               onMouseClicked="#handleVolverLogin">
            <VBox.margin><Insets top="3"/></VBox.margin>
        </Label>

    </VBox>

</StackPane>
