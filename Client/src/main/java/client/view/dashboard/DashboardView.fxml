<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="client.controller.dashboard.DashboardController"
            styleClass="raiz-admin"
            stylesheets="@DashboardView.css">

    <!-- ── Navbar superior ── -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="20">
            <Label text="trenes" styleClass="nav-brand"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblBienvenido" styleClass="nav-user"/>
            <Button fx:id="btnLogout" text="Cerrar sesión"
                    onAction="#handleLogout" styleClass="btn-logout"/>
        </HBox>
    </top>

    <!-- ── Contenido central ── -->
    <center>
        <VBox spacing="0">
            <VBox.margin><Insets top="24" left="28" right="28" bottom="0"/></VBox.margin>

            <!-- Título + filtros -->
            <VBox spacing="4">
                <Label text="Rutas disponibles" styleClass="seccion-titulo"/>
                <Label text="Selecciona una ruta publicada para comprar tu tiquete." styleClass="seccion-subtitulo"/>
            </VBox>

            <Region minHeight="16" maxHeight="16"/>

            <!-- Barra de filtros -->
            <HBox styleClass="barra-acciones" spacing="10" alignment="CENTER_LEFT">
                <Label text="Origen:" styleClass="filtro-label"/>
                <ComboBox fx:id="cmbFiltroOrigen"
                          promptText="Todas las estaciones"
                          styleClass="combo-filtro"
                          prefWidth="200"
                          onAction="#aplicarFiltros"/>

                <Label text="Destino:" styleClass="filtro-label"/>
                <ComboBox fx:id="cmbFiltroDestino"
                          promptText="Todas las estaciones"
                          styleClass="combo-filtro"
                          prefWidth="200"
                          onAction="#aplicarFiltros"/>

                <Button text="X Limpiar filtros" styleClass="btn-limpiar"
                        onAction="#limpiarFiltros"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Actualizar" onAction="#refreshRoutes" styleClass="btn-secundario"/>
            </HBox>

            <Region minHeight="14" maxHeight="14"/>

            <!-- Lista de rutas -->
            <ScrollPane fitToWidth="true" styleClass="scroll-rutas" VBox.vgrow="ALWAYS">
                <VBox fx:id="vboxRutas" spacing="10" styleClass="contenedor-rutas">
                    <VBox.margin><Insets top="4" bottom="16"/></VBox.margin>
                </VBox>
            </ScrollPane>

        </VBox>
    </center>

    <!-- ── Status bar ── -->
    <bottom>
        <Label fx:id="lblLog"
               styleClass="status-bar"/>
    </bottom>

</BorderPane>
