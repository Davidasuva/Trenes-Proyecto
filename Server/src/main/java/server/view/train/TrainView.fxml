<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="server.controller.train.TrainController"
      styleClass="raiz-admin"
      stylesheets="@AdminView.css"
      prefWidth="1100" prefHeight="700">

    <VBox HBox.hgrow="ALWAYS" spacing="0">

        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="20">
            <HBox alignment="CENTER" spacing="8">
                <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                    <image><Image url="@../auth/train-travel-round-icon2-by-Vexels.png"/></image>
                </ImageView>
                <Label text="trenes" styleClass="nav-brand"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="rutas"        styleClass="nav-link" onAction="#irRutas"/>
            <Button text="trenes"       styleClass="nav-link-active"/>
            <Button text="usuarios"     styleClass="nav-link" onAction="#irUsuarios"/>
            <Button text="trabajadores" styleClass="nav-link" onAction="#irTrabajadores"/>
        </HBox>

        <VBox VBox.vgrow="ALWAYS" spacing="0">
            <VBox.margin><Insets top="28" left="28" right="28" bottom="28"/></VBox.margin>

            <VBox spacing="4">
                <Label text="Gestión de Trenes" styleClass="seccion-titulo"/>
                <Label text="Registra y administra los trenes del sistema." styleClass="seccion-subtitulo"/>
            </VBox>

            <Region minHeight="20" maxHeight="20"/>

            <HBox styleClass="barra-acciones" spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtBuscar"
                           promptText="Buscar por ID o nombre..."
                           styleClass="campo-busqueda"
                           prefWidth="260"
                           onKeyReleased="#handleBuscar"/>
                <ComboBox fx:id="cmbFiltroFabricante"
                          promptText="Filtrar por fabricante"
                          styleClass="combo-campo"
                          prefWidth="180"
                          onAction="#handleFiltroFabricante"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ Nuevo Tren" styleClass="btn-primario" onAction="#handleNuevoTren"/>
            </HBox>

            <Region minHeight="14" maxHeight="14"/>

            <TableView fx:id="tablaTrenes" styleClass="tabla" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"          text="ID"          prefWidth="70"/>
                    <TableColumn fx:id="colNombre"      text="Nombre"      prefWidth="160"/>
                    <TableColumn fx:id="colFabricante"  text="Fabricante"  prefWidth="150"/>
                    <TableColumn fx:id="colTipo"        text="Tipo"        prefWidth="140"/>
                    <TableColumn fx:id="colCapacidad"   text="Vagones (P/C)" prefWidth="110"/>
                    <TableColumn fx:id="colKilometraje" text="Km recorr."  prefWidth="110"/>
                    <TableColumn fx:id="colAcciones"    text="Acciones"    prefWidth="140"/>
                </columns>
                <placeholder>
                    <Label text="No hay trenes registrados." styleClass="seccion-subtitulo"/>
                </placeholder>
            </TableView>
        </VBox>
    </VBox>

    <!-- Panel derecho: formulario -->
    <VBox fx:id="panelForm" styleClass="panel-form"
          prefWidth="320" spacing="0"
          visible="false" managed="false">

        <Label fx:id="lblTituloForm" text="Nuevo Tren" styleClass="form-titulo"/>
        <Region minHeight="22" maxHeight="22"/>

        <Label text="ID (solo números)" styleClass="form-label"/>
        <Region minHeight="5" maxHeight="5"/>
        <TextField fx:id="txtId" promptText="Ej: 101" styleClass="campo"/>

        <Region minHeight="14" maxHeight="14"/>

        <Label text="Nombre del tren" styleClass="form-label"/>
        <Region minHeight="5" maxHeight="5"/>
        <TextField fx:id="txtNombre" promptText="Ej: Tren Norte" styleClass="campo"/>

        <Region minHeight="14" maxHeight="14"/>

        <Label text="Fabricante" styleClass="form-label"/>
        <Region minHeight="5" maxHeight="5"/>
        <ComboBox fx:id="cmbFabricante" styleClass="combo-campo" maxWidth="Infinity"
                  promptText="Selecciona el fabricante"/>

        <Region minHeight="14" maxHeight="14"/>

        <Label text="Tipo de tren" styleClass="form-label"/>
        <Region minHeight="5" maxHeight="5"/>
        <ComboBox fx:id="cmbTipo" styleClass="combo-campo" maxWidth="Infinity"
                  promptText="Selecciona el tipo"/>

        <Region minHeight="14" maxHeight="14"/>

        <Label text="Vagones de pasajeros" styleClass="form-label"/>
        <Region minHeight="5" maxHeight="5"/>
        <TextField fx:id="txtVagonesPasajeros" promptText="Ej: 4" styleClass="campo"/>

        <Region minHeight="14" maxHeight="14"/>

        <Label text="Vagones de carga" styleClass="form-label"/>
        <Region minHeight="5" maxHeight="5"/>
        <TextField fx:id="txtVagonesCarga" promptText="Ej: 2  (1 por cada 2 de pasajeros)" styleClass="campo"/>

        <Region minHeight="6" maxHeight="6"/>
        <Label fx:id="lblLimite" styleClass="form-label" wrapText="true"/>

        <Region minHeight="6" maxHeight="6"/>

        <Label fx:id="lblErrorForm" styleClass="form-label" wrapText="true"
               visible="false" managed="false"/>

        <Region VBox.vgrow="ALWAYS"/>
        <Pane styleClass="separador"/>
        <Region minHeight="16" maxHeight="16"/>

        <HBox spacing="10">
            <Button text="Guardar" styleClass="btn-primario" onAction="#handleGuardar"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button text="Cancelar" styleClass="btn-secundario" onAction="#handleCancelar"/>
        </HBox>
    </VBox>
</HBox>