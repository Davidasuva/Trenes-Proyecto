<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="server.controller.ticket.TicketController"
      styleClass="raiz-admin"
      stylesheets="@../route/AdminView.css"
      prefWidth="1400" prefHeight="800">

    <VBox HBox.hgrow="ALWAYS" spacing="0">

        <!-- Navbar -->
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="20">
            <HBox alignment="CENTER" spacing="8">
                <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                    <image>
                        <Image url="@../auth/login/Tren.jpeg"/>
                    </image>
                </ImageView>
                <Label text="trenes" styleClass="nav-brand"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="rutas"     styleClass="nav-link" onAction="#irRutas"/>
            <Button text="trenes"    styleClass="nav-link" onAction="#irTrenes"/>
            <Button text="usuarios"  styleClass="nav-link" onAction="#irUsuarios"/>
            <Button text="tickets"   styleClass="nav-link-active"/>
        </HBox>

        <VBox VBox.vgrow="ALWAYS" spacing="0">
            <VBox.margin><Insets top="28" left="28" right="28" bottom="28"/></VBox.margin>

            <!-- Encabezado -->
            <VBox spacing="4">
                <Label text="Tickets" styleClass="seccion-titulo"/>
                <Label text="Visualiza y edita el estado de los tickets registrados." styleClass="seccion-subtitulo"/>
            </VBox>

            <Region minHeight="20" maxHeight="20"/>

            <!-- Filtros -->
            <HBox styleClass="barra-acciones" spacing="10" alignment="CENTER_LEFT">
                <ComboBox fx:id="cmbFiltroRuta"
                          promptText="Todas las rutas"
                          styleClass="combo-campo"
                          prefWidth="240"
                          onAction="#handleFiltrarRuta"/>
                <ComboBox fx:id="cmbFiltroPasajero"
                          promptText="Todos los pasajeros"
                          styleClass="combo-campo"
                          prefWidth="240"
                          onAction="#handleFiltrarPasajero"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <Region minHeight="14" maxHeight="14"/>

            <!-- Tabla -->
            <TableView fx:id="tablaTickets" styleClass="tabla" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"          text="ID"           prefWidth="130"/>
                    <TableColumn fx:id="colPasajero"    text="Pasajero"     prefWidth="180"/>
                    <TableColumn fx:id="colRuta"        text="Ruta"         prefWidth="160"/>
                    <TableColumn fx:id="colCategoria"   text="Categoría"    prefWidth="110"/>
                    <TableColumn fx:id="colEstado"      text="Estado"       prefWidth="100"/>
                    <TableColumn fx:id="colFechaCompra" text="Fecha compra" prefWidth="130"/>
                    <TableColumn fx:id="colAcciones"    text="Acciones"     prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="No hay tickets que coincidan con los filtros." styleClass="seccion-subtitulo"/>
                </placeholder>
            </TableView>
        </VBox>
    </VBox>

    <!-- Panel edición lateral -->
    <VBox fx:id="panelForm" styleClass="panel-form"
          prefWidth="320" spacing="0"
          visible="false" managed="false">

        <Label fx:id="lblTituloForm" text="Editar Ticket" styleClass="form-titulo"/>
        <Region minHeight="22" maxHeight="22"/>

        <!-- Info de sólo lectura -->
        <Label text="ID del ticket" styleClass="form-label"/>
        <Region minHeight="4" maxHeight="4"/>
        <Label fx:id="lblId" styleClass="campo" style="-fx-text-fill:#6B7280;" wrapText="true"/>

        <Region minHeight="12" maxHeight="12"/>

        <Label text="Pasajero" styleClass="form-label"/>
        <Region minHeight="4" maxHeight="4"/>
        <Label fx:id="lblPasajero" styleClass="campo" style="-fx-text-fill:#6B7280;" wrapText="true"/>

        <Region minHeight="12" maxHeight="12"/>

        <Label text="Ruta" styleClass="form-label"/>
        <Region minHeight="4" maxHeight="4"/>
        <Label fx:id="lblRuta" styleClass="campo" style="-fx-text-fill:#6B7280;" wrapText="true"/>

        <Region minHeight="12" maxHeight="12"/>

        <Label text="Fecha de compra" styleClass="form-label"/>
        <Region minHeight="4" maxHeight="4"/>
        <Label fx:id="lblFechaCompra" styleClass="campo" style="-fx-text-fill:#6B7280;"/>

        <Region minHeight="12" maxHeight="12"/>

        <Label text="Categoría" styleClass="form-label"/>
        <Region minHeight="4" maxHeight="4"/>
        <Label fx:id="lblCategoria" styleClass="campo" style="-fx-text-fill:#6B7280;"/>

        <Region minHeight="18" maxHeight="18"/>

        <!-- Campo editable: estado -->
        <Label text="Estado del ticket" styleClass="form-label"/>
        <Region minHeight="5" maxHeight="5"/>
        <ComboBox fx:id="cmbEstado" styleClass="combo-campo" maxWidth="Infinity"
                  promptText="Selecciona estado"/>

        <Region minHeight="6" maxHeight="6"/>

        <Label fx:id="lblErrorForm" styleClass="form-label"
               style="-fx-text-fill:#e53e3e;" wrapText="true"
               visible="false" managed="false"/>

        <Region VBox.vgrow="ALWAYS"/>
        <Pane styleClass="separador"/>
        <Region minHeight="16" maxHeight="16"/>

        <HBox spacing="10">
            <Button text="Guardar" styleClass="btn-primario" onAction="#handleGuardar"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button text="Cancelar" styleClass="btn-secundario" onAction="#handleCancelar"/>
        </HBox>
    </VBox>

</HBox>
