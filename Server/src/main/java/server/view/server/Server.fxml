<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="0" alignment="TOP_CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="server.controller.ServerController"
      styleClass="raiz-server"
      stylesheets="@Server.css">

    <!-- ── Navbar ── -->
    <HBox styleClass="navbar-server" alignment="CENTER_LEFT" spacing="16">
        <Label text="trenes — Server" styleClass="nav-brand-server"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblStatus"
               text="● Stopped"
               styleClass="status-label status-stopped"/>
    </HBox>

    <!-- ── Cuerpo principal ── -->
    <VBox VBox.vgrow="ALWAYS" spacing="16">
        <VBox.margin><Insets top="20" left="20" right="20" bottom="20"/></VBox.margin>

        <!-- Fila de acciones: Deploy + Ir al Menú -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button fx:id="btnDeploy"
                    text="Deploy Server"
                    styleClass="btn-deploy"
                    onAction="#handleDeploy"/>
            <Button fx:id="btnIrMenu"
                    text="Ir al Menú →"
                    styleClass="btn-menu"
                    disable="true"
                    onAction="#handleIrMenu"/>
        </HBox>

        <!-- Consola de eventos -->
        <TextArea fx:id="txtConsola"
                  editable="false"
                  wrapText="true"
                  promptText="Esperando eventos..."
                  VBox.vgrow="ALWAYS"
                  styleClass="consola"/>

    </VBox>

</VBox>