<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="server.controller.route.RouteController"
      styleClass="raiz-admin"
      stylesheets="@AdminView.css"
      prefWidth="1100" prefHeight="700">

    <VBox HBox.hgrow="ALWAYS" spacing="0">

        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="20">
            <HBox alignment="CENTER" spacing="8">
                <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                    <image><Image url="@../auth/train-travel-round-icon2-by-Vexels.png"/></image>
                </ImageView>
                <Label text="trenes" styleClass="nav-brand"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="rutas"        styleClass="nav-link-active"/>
            <Button text="trenes"       styleClass="nav-link" onAction="#irTrenes"/>
            <Button text="usuarios"     styleClass="nav-link" onAction="#irUsuarios"/>
            <Button text="trabajadores" styleClass="nav-link" onAction="#irTrabajadores"/>
        </HBox>

        <VBox VBox.vgrow="ALWAYS" spacing="0">
            <VBox.margin><Insets top="28" left="28" right="28" bottom="28"/></VBox.margin>

            <VBox spacing="4">
                <Label text="Gestión de Rutas" styleClass="seccion-titulo"/>
                <Label text="Configura rutas con tren, origen, destino y estaciones intermedias." styleClass="seccion-subtitulo"/>
            </VBox>

            <Region minHeight="20" maxHeight="20"/>

            <HBox styleClass="barra-acciones" spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtBuscar"
                           promptText="Buscar por nombre, origen o destino..."
                           styleClass="campo-busqueda"
                           prefWidth="340"
                           onKeyReleased="#handleBuscar"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ Nueva Ruta" styleClass="btn-primario" onAction="#handleNuevaRuta"/>
            </HBox>

            <Region minHeight="14" maxHeight="14"/>

            <TableView fx:id="tablaRutas" styleClass="tabla" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"       text="ID"        prefWidth="60"/>
                    <TableColumn fx:id="colNombre"   text="Nombre"    prefWidth="160"/>
                    <TableColumn fx:id="colOrigen"   text="Origen"    prefWidth="160"/>
                    <TableColumn fx:id="colDestino"  text="Destino"   prefWidth="160"/>
                    <TableColumn fx:id="colDistancia" text="Dist. km" prefWidth="90"/>
                    <TableColumn fx:id="colEstado"   text="Estado"    prefWidth="90"/>
                    <TableColumn fx:id="colAcciones" text="Acciones"  prefWidth="350"/>
                </columns>
                <placeholder>
                    <Label text="No hay rutas registradas." styleClass="seccion-subtitulo"/>
                </placeholder>
            </TableView>
        </VBox>
    </VBox>

    <!-- Panel derecho: formulario -->
    <VBox fx:id="panelForm" styleClass="panel-form"
          prefWidth="340" spacing="0"
          visible="false" managed="false">

        <Label fx:id="lblTituloForm" text="Nueva Ruta" styleClass="form-titulo"/>
        <Region minHeight="18" maxHeight="18"/>

        <Label text="Nombre de la ruta" styleClass="form-label"/>
        <Region minHeight="5" maxHeight="5"/>
        <TextField fx:id="txtNombre" promptText="Ej: Ruta Norte" styleClass="campo"/>

        <Region minHeight="12" maxHeight="12"/>

        <Label text="Tren asignado" styleClass="form-label"/>
        <Region minHeight="5" maxHeight="5"/>
        <ComboBox fx:id="cmbTren" styleClass="combo-campo" maxWidth="Infinity"
                  promptText="Selecciona un tren"/>

        <Region minHeight="12" maxHeight="12"/>

        <Label text="Origen" styleClass="form-label"/>
        <Region minHeight="5" maxHeight="5"/>
        <ComboBox fx:id="cmbOrigen" styleClass="combo-campo" maxWidth="Infinity"
                  promptText="Estación de origen"
                  onAction="#handleOrigenCambio"/>

        <Region minHeight="12" maxHeight="12"/>

        <Label text="Destino" styleClass="form-label"/>
        <Region minHeight="5" maxHeight="5"/>
        <ComboBox fx:id="cmbDestino" styleClass="combo-campo" maxWidth="Infinity"
                  promptText="Estación de destino"
                  onAction="#handleDestinoCambio"/>

        <Region minHeight="12" maxHeight="12"/>

        <!-- Estaciones intermedias (del camino calculado) -->
        <Label text="Estaciones en la ruta" styleClass="form-label"/>
        <Region minHeight="5" maxHeight="5"/>
        <Label fx:id="lblEstaciones" text="Selecciona origen y destino"
               styleClass="seccion-subtitulo" wrapText="true"/>

        <Region minHeight="12" maxHeight="12"/>

        <Label text="Fecha de salida" styleClass="form-label"/>
        <Region minHeight="5" maxHeight="5"/>
        <TextField fx:id="txtFechaSalida" promptText="DD/MM/AAAA" styleClass="campo"/>

        <Region minHeight="12" maxHeight="12"/>

        <Label text="Fecha de llegada" styleClass="form-label"/>
        <Region minHeight="5" maxHeight="5"/>
        <TextField fx:id="txtFechaLlegada" promptText="DD/MM/AAAA" styleClass="campo"/>

        <Region minHeight="6" maxHeight="6"/>

        <Label fx:id="lblErrorForm" styleClass="form-label" wrapText="true"
               visible="false" managed="false"/>

        <Region VBox.vgrow="ALWAYS"/>
        <Pane styleClass="separador"/>
        <Region minHeight="16" maxHeight="16"/>

        <HBox spacing="10">
            <Button text="Guardar" styleClass="btn-primario" onAction="#handleGuardar"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button text="Cancelar" styleClass="btn-secundario" onAction="#handleCancelar"/>
        </HBox>
    </VBox>

    <!-- Panel de orden de abordaje -->
    <VBox fx:id="panelAbordaje" styleClass="panel-form"
          prefWidth="340" spacing="0"
          visible="false" managed="false">

        <Label fx:id="lblTituloAbordaje" text="Orden de Abordaje" styleClass="form-titulo"/>
        <Region minHeight="10" maxHeight="10"/>

        <TextArea fx:id="txtOrdenAbordaje"
                  editable="false" wrapText="true"
                  VBox.vgrow="ALWAYS"
                  styleClass="consola"
                  prefHeight="560"/>

        <Region minHeight="12" maxHeight="12"/>
        <Button text="Cerrar" styleClass="btn-secundario"
                onAction="#handleCerrarAbordaje"
                maxWidth="Infinity"/>
    </VBox>
</HBox>